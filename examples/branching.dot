digraph branching {
  start [shape=Mdiamond];
  decide [handler=conditional, condition="branch=left"];
  left [handler=codergen, prompt="left path"];
  right [handler=codergen, prompt="right path"];
  exit [shape=Msquare];
  start -> decide;
  decide -> left [label=true, weight=2];
  decide -> right [label=false, weight=1];
  left -> exit [weight=1];
  right -> exit [weight=1];
}
