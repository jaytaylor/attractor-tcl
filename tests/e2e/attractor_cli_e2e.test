package require tcltest
namespace import ::tcltest::*

set root [file normalize [file join [file dirname [info script]] .. ..]]

namespace eval ::tests::e2e {}
set ::tests::e2e::root $root

proc ::tests::e2e::run_attractor {dotPath logsRoot} {
    variable root
    set cmd [list [file join $root bin attractor] run $dotPath --logs-root $logsRoot]
    if {[catch {exec {*}$cmd} out]} {
        return [dict create ok 0 output $out]
    }
    return [dict create ok 1 output $out]
}

test e2e-attractor-cli-linear-1.0 {CLI runs linear pipeline and writes artifacts} -setup {
    set logsRoot [file join $root .scratch verification SPRINT-001 integration e2e-linear-[pid]]
    file delete -force $logsRoot
} -body {
    set result [::tests::e2e::run_attractor [file join $root examples linear.dot] $logsRoot]
    list [dict get $result ok] [file exists [file join $logsRoot checkpoint.json]] [file exists [file join $logsRoot build status.json]]
} -cleanup {
    file delete -force $logsRoot
} -result {1 1 1}

test e2e-attractor-cli-resume-1.0 {CLI supports resume from checkpoint} -setup {
    set logsRoot [file join $root .scratch verification SPRINT-001 integration e2e-resume-[pid]]
    file delete -force $logsRoot
    file mkdir $logsRoot
    set checkpoint [file join $logsRoot checkpoint.json]
    set fh [open $checkpoint w]
    puts -nonewline $fh {{"timestamp":"now","current_node":"build","completed_nodes":["start"],"node_retries":{},"context_values":{}}}
    close $fh
} -body {
    set cmd [list [file join $root bin attractor] run [file join $root examples linear.dot] --logs-root $logsRoot --resume]
    catch {exec {*}$cmd} out
    list [expr {[string first "\"status\":\"success\"" $out] >= 0}] [file exists [file join $logsRoot build status.json]]
} -cleanup {
    file delete -force $logsRoot
} -result {1 1}

test e2e-attractor-cli-validate-1.0 {CLI validates dot pipelines without execution} -body {
    set cmd [list [file join $root bin attractor] validate [file join $root examples linear.dot]]
    set out [exec {*}$cmd]
    expr {[string first "\"status\":\"valid\"" $out] >= 0}
} -result 1

test e2e-attractor-cli-validate-negative-1.0 {CLI validate fails on malformed graph} -setup {
    set bad [file join $root .scratch verification SPRINT-001 integration e2e-bad-[pid].dot]
    set fh [open $bad w]
    puts -nonewline $fh {digraph bad { start [shape=start]; node -> ; }}
    close $fh
} -body {
    set cmd [list [file join $root bin attractor] validate $bad]
    catch {exec {*}$cmd} out
    string match "*validation_failed*" $out
} -cleanup {
    file delete -force $bad
} -result 1

test e2e-attractor-cli-resume-negative-1.0 {CLI resume fails on corrupted checkpoint} -setup {
    set logsRoot [file join $root .scratch verification SPRINT-001 integration e2e-resume-bad-[pid]]
    file delete -force $logsRoot
    file mkdir $logsRoot
    set checkpoint [file join $logsRoot checkpoint.json]
    set fh [open $checkpoint w]
    puts -nonewline $fh "not-json"
    close $fh
} -body {
    set cmd [list [file join $root bin attractor] run [file join $root examples linear.dot] --logs-root $logsRoot --resume]
    set code [catch {exec {*}$cmd} out]
    list $code [expr {[string length $out] > 0}]
} -cleanup {
    file delete -force $logsRoot
} -result {1 1}
