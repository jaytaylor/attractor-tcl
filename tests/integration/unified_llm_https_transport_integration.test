package require tcltest
namespace import ::tcltest::*

set root [file normalize [file join [file dirname [info script]] .. ..]]
lappend auto_path $root
package require unified_llm
package require attractor_core
source [file join $root tests support http_fixture_server.tcl]

namespace eval ::tests::integration::https_transport {}

test integration-unified-llm-https-transport-happy-1.0 {transport sends JSON and redacts sensitive response request headers} -setup {
    set body [::attractor_core::json_encode [dict create \
        id "resp-123" \
        output_text "hello from fixture" \
        usage [dict create input_tokens 4 output_tokens 6 reasoning_tokens 0 cache_read_tokens 0 cache_write_tokens 0]]]
    set server [::tests::http_fixture_server::new [list [dict create status_code 200 headers [dict create X-Request-Id req-1] body $body]]]
    set client [::unified_llm::client_new \
        -provider openai \
        -api_key "sk-test-secret" \
        -base_url [$server url] \
        -transport ::unified_llm::transports::https_json::call]
} -body {
    set response [::unified_llm::generate -client $client -provider openai -prompt "Say hello in one sentence." -model gpt-4o-mini]
    set requests [$server requests]
    set request [lindex $requests 0]
    set payload [::attractor_core::json_decode [dict get $request body]]
    list \
        [dict get $request path] \
        [dict get $request headers Content-Type] \
        [dict get $request headers Authorization] \
        [dict get $payload model] \
        [dict get $response text] \
        [dict get $response request headers Authorization]
} -cleanup {
    $client close
    $server close
} -result {/v1/responses application/json {Bearer sk-test-secret} gpt-4o-mini {hello from fixture} <redacted>}

test integration-unified-llm-https-transport-http-error-1.0 {transport raises deterministic HTTP errorcode without secrets} -setup {
    set body [::attractor_core::json_encode [dict create error [dict create message "bad key"]]]
    set server [::tests::http_fixture_server::new [list [dict create status_code 401 headers {} body $body]]]
    set client [::unified_llm::client_new \
        -provider openai \
        -api_key "sk-secret-live-key" \
        -base_url [$server url] \
        -transport ::unified_llm::transports::https_json::call]
} -body {
    set code [catch {::unified_llm::generate -client $client -provider openai -prompt "hello" -model gpt-4o-mini} err opts]
    list $code [dict get $opts -errorcode] [expr {[string first "sk-secret-live-key" $err] < 0}]
} -cleanup {
    $client close
    $server close
} -result {1 {UNIFIED_LLM TRANSPORT HTTP openai 401} 1}

test integration-unified-llm-https-transport-network-error-1.0 {transport raises deterministic network errorcode} -setup {
    set client [::unified_llm::client_new \
        -provider openai \
        -api_key "sk-anything" \
        -base_url "http://127.0.0.1:9" \
        -transport ::unified_llm::transports::https_json::call]
} -body {
    catch {::unified_llm::generate -client $client -provider openai -prompt "hello" -model gpt-4o-mini} err opts
    dict get $opts -errorcode
} -cleanup {
    $client close
} -result {UNIFIED_LLM TRANSPORT NETWORK openai}
