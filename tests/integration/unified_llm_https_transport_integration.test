package require tcltest
namespace import ::tcltest::*

set root [file normalize [file join [file dirname [info script]] .. ..]]
lappend auto_path $root
package require unified_llm
package require attractor_core
source [file join $root tests support http_fixture_server.tcl]

namespace eval ::tests::integration::https_transport {}

proc ::tests::integration::https_transport::save_tls_impls {} {
    return [dict create \
        require $::unified_llm::transports::https_json::tls_require_impl \
        provide $::unified_llm::transports::https_json::tls_provide_impl \
        register $::unified_llm::transports::https_json::tls_register_impl]
}

proc ::tests::integration::https_transport::restore_tls_impls {saved} {
    set ::unified_llm::transports::https_json::tls_require_impl [dict get $saved require]
    set ::unified_llm::transports::https_json::tls_provide_impl [dict get $saved provide]
    set ::unified_llm::transports::https_json::tls_register_impl [dict get $saved register]
    ::unified_llm::transports::https_json::__reset_https_registration_state
}

proc ::tests::integration::https_transport::tls_require_missing {} {
    error "can't find package tls"
}

proc ::tests::integration::https_transport::tls_require_legacy {} {
    return "1.6.1"
}

proc ::tests::integration::https_transport::tls_require_modern {} {
    return "1.7.22"
}

proc ::tests::integration::https_transport::tls_provide_legacy {} {
    return "1.6.1"
}

proc ::tests::integration::https_transport::tls_provide_modern {} {
    return "1.7.22"
}

proc ::tests::integration::https_transport::tls_register_ok {} {
    variable register_count
    incr register_count
    return ""
}

proc ::tests::integration::https_transport::tls_register_fail {} {
    variable register_count
    incr register_count
    error "simulated register failure"
}

test integration-unified-llm-https-transport-join-url-default-1.0 {join_url appends endpoint when base has no path suffix} -body {
    ::unified_llm::transports::https_json::__join_url "https://api.openai.com" "/v1/responses"
} -result {https://api.openai.com/v1/responses}

test integration-unified-llm-https-transport-join-url-dedup-1.0 {join_url avoids duplicate /v1 prefix when base already has it} -body {
    ::unified_llm::transports::https_json::__join_url "http://127.0.0.1:58298/v1" "/v1/responses"
} -result {http://127.0.0.1:58298/v1/responses}

test integration-unified-llm-https-transport-happy-1.0 {transport sends JSON and redacts sensitive response request headers} -setup {
    set body [::attractor_core::json_encode [dict create \
        id "resp-123" \
        output_text "hello from fixture" \
        usage [dict create input_tokens 4 output_tokens 6 reasoning_tokens 0 cache_read_tokens 0 cache_write_tokens 0]]]
    set server [::tests::http_fixture_server::new [list [dict create status_code 200 headers [dict create X-Request-Id req-1] body $body]]]
    set client [::unified_llm::client_new \
        -provider openai \
        -api_key "sk-test-secret" \
        -base_url [$server url] \
        -transport ::unified_llm::transports::https_json::call]
} -body {
    set response [::unified_llm::generate -client $client -provider openai -prompt "Say hello in one sentence." -model gpt-4o-mini]
    set requests [$server requests]
    set request [lindex $requests 0]
    set payload [::attractor_core::json_decode [dict get $request body]]
    set firstInput [lindex [dict get $payload input] 0]
    set firstPart [lindex [dict get $firstInput content] 0]
    list \
        [dict get $request path] \
        [dict get $request headers Content-Type] \
        [dict get $request headers Authorization] \
        [dict get $payload model] \
        [dict get $firstInput role] \
        [dict get $firstPart type] \
        [dict get $firstPart text] \
        [dict get $response text] \
        [dict get $response request headers Authorization]
} -cleanup {
    $client close
    $server close
} -result {/v1/responses application/json {Bearer sk-test-secret} gpt-4o-mini user input_text {Say hello in one sentence.} {hello from fixture} <redacted>}

test integration-unified-llm-https-transport-http-error-1.0 {transport raises deterministic HTTP errorcode without secrets} -setup {
    set body [::attractor_core::json_encode [dict create error [dict create message "bad key"]]]
    set server [::tests::http_fixture_server::new [list [dict create status_code 401 headers {} body $body]]]
    set client [::unified_llm::client_new \
        -provider openai \
        -api_key "sk-secret-live-key" \
        -base_url [$server url] \
        -transport ::unified_llm::transports::https_json::call]
} -body {
    set code [catch {::unified_llm::generate -client $client -provider openai -prompt "hello" -model gpt-4o-mini} err opts]
    list $code [dict get $opts -errorcode] [expr {[string first "sk-secret-live-key" $err] < 0}]
} -cleanup {
    $client close
    $server close
} -result {1 {UNIFIED_LLM TRANSPORT HTTP openai 401} 1}

test integration-unified-llm-https-transport-network-error-1.0 {transport raises deterministic network errorcode} -setup {
    set client [::unified_llm::client_new \
        -provider openai \
        -api_key "sk-anything" \
        -base_url "http://127.0.0.1:9" \
        -transport ::unified_llm::transports::https_json::call]
} -body {
    catch {::unified_llm::generate -client $client -provider openai -prompt "hello" -model gpt-4o-mini} err opts
    dict get $opts -errorcode
} -cleanup {
    $client close
} -result {UNIFIED_LLM TRANSPORT NETWORK openai}

test integration-unified-llm-https-transport-missing-tls-1.0 {missing tls package fails with deterministic NETWORK error and remediation hint} -setup {
    set saved [::tests::integration::https_transport::save_tls_impls]
    set ::unified_llm::transports::https_json::tls_require_impl [list ::tests::integration::https_transport::tls_require_missing]
    set ::unified_llm::transports::https_json::tls_provide_impl [list ::tests::integration::https_transport::tls_provide_legacy]
    set ::unified_llm::transports::https_json::tls_register_impl [list ::tests::integration::https_transport::tls_register_ok]
    ::unified_llm::transports::https_json::__reset_https_registration_state
} -body {
    set code [catch {::unified_llm::transports::https_json::__ensure_https_registered openai} err opts]
    list \
        $code \
        [dict get $opts -errorcode] \
        [expr {[string first "requires tls >=" $err] >= 0}] \
        [expr {[string first "Install tcl-tls" $err] >= 0}]
} -cleanup {
    ::tests::integration::https_transport::restore_tls_impls $saved
} -result {1 {UNIFIED_LLM TRANSPORT NETWORK openai} 1 1}

test integration-unified-llm-https-transport-unsupported-tls-1.0 {unsupported tls version fails with deterministic NETWORK error and remediation hint} -setup {
    set saved [::tests::integration::https_transport::save_tls_impls]
    set ::unified_llm::transports::https_json::tls_require_impl [list ::tests::integration::https_transport::tls_require_legacy]
    set ::unified_llm::transports::https_json::tls_provide_impl [list ::tests::integration::https_transport::tls_provide_legacy]
    set ::unified_llm::transports::https_json::tls_register_impl [list ::tests::integration::https_transport::tls_register_ok]
    ::unified_llm::transports::https_json::__reset_https_registration_state
} -body {
    set code [catch {::unified_llm::transports::https_json::__ensure_https_registered anthropic} err opts]
    list \
        $code \
        [dict get $opts -errorcode] \
        [expr {[string first "tls runtime 1.6.1 is unsupported" $err] >= 0}] \
        [expr {[string first "TCLSH" $err] >= 0}]
} -cleanup {
    ::tests::integration::https_transport::restore_tls_impls $saved
} -result {1 {UNIFIED_LLM TRANSPORT NETWORK anthropic} 1 1}

test integration-unified-llm-https-transport-registration-idempotent-1.0 {https registration runs once for repeated initialization} -setup {
    set saved [::tests::integration::https_transport::save_tls_impls]
    set ::tests::integration::https_transport::register_count 0
    set ::unified_llm::transports::https_json::tls_require_impl [list ::tests::integration::https_transport::tls_require_modern]
    set ::unified_llm::transports::https_json::tls_provide_impl [list ::tests::integration::https_transport::tls_provide_modern]
    set ::unified_llm::transports::https_json::tls_register_impl [list ::tests::integration::https_transport::tls_register_ok]
    ::unified_llm::transports::https_json::__reset_https_registration_state
} -body {
    ::unified_llm::transports::https_json::__ensure_https_registered openai
    ::unified_llm::transports::https_json::__ensure_https_registered openai
    set ::tests::integration::https_transport::register_count
} -cleanup {
    ::tests::integration::https_transport::restore_tls_impls $saved
} -result 1

test integration-unified-llm-https-transport-registration-failure-cached-1.0 {registration failure maps to deterministic NETWORK errors and does not re-register} -setup {
    set saved [::tests::integration::https_transport::save_tls_impls]
    set ::tests::integration::https_transport::register_count 0
    set ::unified_llm::transports::https_json::tls_require_impl [list ::tests::integration::https_transport::tls_require_modern]
    set ::unified_llm::transports::https_json::tls_provide_impl [list ::tests::integration::https_transport::tls_provide_modern]
    set ::unified_llm::transports::https_json::tls_register_impl [list ::tests::integration::https_transport::tls_register_fail]
    ::unified_llm::transports::https_json::__reset_https_registration_state
} -body {
    catch {::unified_llm::transports::https_json::__ensure_https_registered openai} err1 opts1
    catch {::unified_llm::transports::https_json::__ensure_https_registered gemini} err2 opts2
    list \
        [dict get $opts1 -errorcode] \
        [dict get $opts2 -errorcode] \
        $::tests::integration::https_transport::register_count \
        [expr {[string first "failed to register ::tls::socket handler" $err2] >= 0}]
} -cleanup {
    ::tests::integration::https_transport::restore_tls_impls $saved
} -result {{UNIFIED_LLM TRANSPORT NETWORK openai} {UNIFIED_LLM TRANSPORT NETWORK gemini} 1 1}
