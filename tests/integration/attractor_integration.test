test integration-attractor-manager-loop-stop-condition-success-1.0 {manager loop can terminate early on explicit stop condition} -setup {
    set logsRoot [file join $root .scratch verification SPRINT-006 integration manager-loop-stop-condition-success-[pid]]
    file delete -force $logsRoot
    file mkdir $logsRoot

    set childDotPath [file join $logsRoot child.dot]
    set fh [open $childDotPath w]
    puts -nonewline $fh {
        digraph child {
            start [shape=Mdiamond];
            build [handler=codergen, prompt="child-build"];
            exit [shape=Msquare];
            start -> build;
            build -> exit [label=success];
        }
    }
    close $fh

    set graph [::attractor::parse_dot [format {
        digraph parent {
            graph [stack.child_dotfile="%s", stack.child_autostart=false];
            start [shape=Mdiamond];
            supervise [shape=house, manager.max_cycles=3, manager.stop_condition="outcome=not_started"];
            exit [shape=Msquare];
            start -> supervise;
            supervise -> exit;
        }
    } $childDotPath]]
} -body {
    set result [::attractor::run $graph -backend ::tests::integration::attractor::manager_backend -logs_root $logsRoot]
    list [dict get $result status] [dict get $result current_node]
} -cleanup {
    file delete -force $logsRoot
} -result {success exit}
