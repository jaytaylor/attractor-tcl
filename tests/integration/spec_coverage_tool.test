test integration-spec-coverage-tool-malformed-catalog-json-2.0 {fails when requirements catalog is malformed JSON} -setup {
    set dir [::tests::integration::spec_cov::tmpdir]
    set reqPath [file join $dir requirements.json]
    set tracePath [file join $dir traceability.md]
    ::tests::integration::spec_cov::write_file $reqPath "not-json"
