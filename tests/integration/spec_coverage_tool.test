package require tcltest
namespace import ::tcltest::*

set root [file normalize [file join [file dirname [info script]] .. ..]]
set tool [file join $root tools spec_coverage.tcl]

namespace eval ::tests::integration::spec_cov {
    variable idx 0
}

proc ::tests::integration::spec_cov::tmpdir {} {
    variable idx
    incr idx
    set dir [file join [pwd] .scratch verification SPRINT-002 coverage spec-coverage-tool-$idx]
    file delete -force $dir
    file mkdir $dir
    return $dir
}

proc ::tests::integration::spec_cov::write_file {path body} {
    file mkdir [file dirname $path]
    set fh [open $path w]
    puts -nonewline $fh $body
    close $fh
}

proc ::tests::integration::spec_cov::requirements_json {ids} {
    set entries {}
    foreach id $ids {
        lappend entries "{\"id\":\"$id\"}"
    }
    set body "\{\"requirements\":\["
    append body [join $entries ,]
    append body "\]\}"
    return $body
}

test integration-spec-coverage-tool-valid-2.0 {passes when traceability and catalog sets are equal} -setup {
    set dir [::tests::integration::spec_cov::tmpdir]
    set reqPath [file join $dir requirements.json]
    set tracePath [file join $dir traceability.md]
    ::tests::integration::spec_cov::write_file $reqPath [::tests::integration::spec_cov::requirements_json [list \
        ULLM-DOD-8.1-CORE-CLIENT \
        CAL-DOD-9.1-TOOL-REGISTRY]]
    ::tests::integration::spec_cov::write_file $tracePath [join [list \
"id: CAL-DOD-9.1-TOOL-REGISTRY" \
"spec: coding-agent-loop-spec.md#section-9" \
"impl: lib/coding_agent_loop/main.tcl" \
"tests: tests/unit/coding_agent_loop.test" \
"verify: `tclsh tests/all.tcl -match *`" \
"---" \
"id: ULLM-DOD-8.1-CORE-CLIENT" \
"spec: unified-llm-spec.md#section-8" \
"impl: lib/unified_llm/main.tcl" \
"tests: tests/unit/unified_llm.test" \
"verify: `tclsh tests/all.tcl -match *`" \
] "\n"]
} -body {
    set out [exec tclsh $tool --trace $tracePath --requirements $reqPath]
    list \
        [expr {[string first "requirements=2" $out] >= 0}] \
        [expr {[string first "missing_catalog=0" $out] >= 0}] \
        [expr {[string first "unknown_catalog=0" $out] >= 0}]
} -cleanup {
    file delete -force $dir
} -result {1 1 1}

test integration-spec-coverage-tool-missing-field-2.0 {fails when required keys are missing} -setup {
    set dir [::tests::integration::spec_cov::tmpdir]
    set reqPath [file join $dir requirements.json]
    set tracePath [file join $dir traceability.md]
    ::tests::integration::spec_cov::write_file $reqPath [::tests::integration::spec_cov::requirements_json [list ULLM-DOD-8.1-CORE-CLIENT]]
    ::tests::integration::spec_cov::write_file $tracePath [join [list \
"id: ULLM-DOD-8.1-CORE-CLIENT" \
"spec: unified-llm-spec.md#section-8" \
"tests: tests/unit/unified_llm.test" \
"verify: `tclsh tests/all.tcl -match *`" \
] "\n"]
} -body {
    catch {exec tclsh $tool --trace $tracePath --requirements $reqPath} out
    list \
        [expr {[string first "MISSING ULLM-DOD-8.1-CORE-CLIENT impl" $out] >= 0}] \
        [expr {[string first "missing=1" $out] >= 0}]
} -cleanup {
    file delete -force $dir
} -result {1 1}

