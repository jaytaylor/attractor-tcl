} -result {1 1}

test integration-spec-coverage-tool-bad-path-2.0 {fails non-existent impl/tests paths} -setup {
    set dir [::tests::integration::spec_cov::tmpdir]
    set reqPath [file join $dir requirements.json]
    set tracePath [file join $dir traceability.md]
    ::tests::integration::spec_cov::write_file $reqPath [::tests::integration::spec_cov::requirements_json [list CAL-DOD-9.10-EVENTS]]
    ::tests::integration::spec_cov::write_file $tracePath [join [list \
"id: CAL-DOD-9.10-EVENTS" \
"spec: coding-agent-loop-spec.md#section-9" \
"impl: lib/coding_agent_loop/missing.tcl" \
"tests: tests/unit/missing.test" \
"verify: `tclsh tests/all.tcl -match *`" \
] "\n"]
} -body {
    catch {exec tclsh $tool --trace $tracePath --requirements $reqPath} out
    list \
        [expr {[string first "BAD_PATH CAL-DOD-9.10-EVENTS impl lib/coding_agent_loop/missing.tcl" $out] >= 0}] \
        [expr {[string first "BAD_PATH CAL-DOD-9.10-EVENTS tests tests/unit/missing.test" $out] >= 0}] \
        [expr {[string first "bad_paths=2" $out] >= 0}]
} -cleanup {
    file delete -force $dir
} -result {1 1 1}

