package require tcltest
namespace import ::tcltest::*

foreach provider [::tests::e2e_live::selected_providers] {
    test e2e-live-attractor-$provider-smoke-1.0 "live attractor smoke for $provider" \
        -body [list ::tests::e2e_live::run_attractor_smoke $provider] \
        -result 1

    test e2e-live-attractor-$provider-invalid-key-1.0 "live attractor invalid-key for $provider" \
        -body [list ::tests::e2e_live::run_attractor_invalid_key $provider] \
        -result 1
}
