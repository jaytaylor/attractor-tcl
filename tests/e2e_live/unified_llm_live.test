package require tcltest
namespace import ::tcltest::*

foreach provider [::tests::e2e_live::selected_providers] {
    test e2e-live-unified-llm-$provider-smoke-1.0 "live unified_llm smoke for $provider" \
        -body [list ::tests::e2e_live::run_unified_llm_smoke $provider] \
        -result 1

    test e2e-live-unified-llm-$provider-invalid-key-1.0 "live unified_llm invalid-key for $provider" \
        -body [list ::tests::e2e_live::run_unified_llm_invalid_key $provider] \
        -result 1
}
