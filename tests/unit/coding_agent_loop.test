package require tcltest
namespace import ::tcltest::*

set root [file normalize [file join [file dirname [info script]] .. ..]]
lappend auto_path $root
package require coding_agent_loop
package require unified_llm
package require attractor_core

namespace eval ::tests::coding_agent_loop {
    variable call_count 0
    variable seen {}
}

proc ::tests::coding_agent_loop::transport_tool {req} {
    variable call_count
    incr call_count

    if {$call_count % 2 == 1} {
        set body {{"id":"first","output_text":"","tool_calls":[{"id":"call1","name":"shell","arguments":{"command":"printf \"abcdef\\nline2\\nline3\\nline4\\n\""}}],"usage":{"input_tokens":1,"output_tokens":1,"reasoning_tokens":0,"cache_read_tokens":0,"cache_write_tokens":0}}}
    } else {
        set body [::attractor_core::json_encode [dict create id second output_text done usage [dict create input_tokens 1 output_tokens 1 reasoning_tokens 0 cache_read_tokens 0 cache_write_tokens 0]]]
    }

    return [dict create status_code 200 headers {} body $body]
}

proc ::tests::coding_agent_loop::transport_plain {req} {
    set prompt ""
    if {[dict exists $req payload input]} {
        foreach item [dict get $req payload input] {
            if {![dict exists $item role] || [dict get $item role] ne "user"} {
                continue
            }
            foreach part [dict get $item content] {
                if {[dict exists $part text]} {
                    set prompt [dict get $part text]
                }
            }
        }
    }
    set body [::attractor_core::json_encode [dict create id plain output_text "ok:$prompt" usage [dict create input_tokens 1 output_tokens 1 reasoning_tokens 0 cache_read_tokens 0 cache_write_tokens 0]]]
    return [dict create status_code 200 headers {} body $body]
}

test coding_agent_loop-env-filter-1.0 {default env filter removes secrets} -setup {
    set ::env(TEST_API_KEY) hidden
    set ::env(TEST_SECRET) hidden
    set ::env(TEST_TOKEN) hidden
    set ::env(TEST_PASSWORD) hidden
    set ::env(TEST_CREDENTIAL) hidden
    set ::env(TEST_VISIBLE) visible
} -body {
    set filtered [::coding_agent_loop::default_env]
    list \
      [dict exists $filtered TEST_API_KEY] \
      [dict exists $filtered TEST_SECRET] \
      [dict exists $filtered TEST_VISIBLE]
} -cleanup {
    unset -nocomplain ::env(TEST_API_KEY) ::env(TEST_SECRET) ::env(TEST_TOKEN) ::env(TEST_PASSWORD) ::env(TEST_CREDENTIAL) ::env(TEST_VISIBLE)
} -result {0 0 1}

test coding_agent_loop-execution-env-1.0 {local execution environment supports file ops} -setup {
    set work [file join $root .scratch verification SPRINT-003 cal env-[pid]]
    file delete -force $work
    file mkdir $work
    set envCmd [::coding_agent_loop::tools::execution_environment_new -type local -root $work]
} -body {
    $envCmd write_file a.txt hello
    set read1 [$envCmd read_file a.txt]
    $envCmd edit_file a.txt hello world
    set read2 [$envCmd read_file a.txt]
    set patch [join [list "*** Begin Patch" "*** Add File: b.txt" "+patch" "*** End Patch"] "\n"]
    $envCmd apply_patch $patch
    list $read1 $read2 [$envCmd read_file b.txt]
} -cleanup {
    $envCmd close
    file delete -force $work
} -result {hello world patch}

test coding_agent_loop-truncate-order-1.0 {truncation applies char then line} -body {
    set full "12345\n67890\nabcde\nfghij\nzzzzz"
    set trunc [::coding_agent_loop::tools::truncate_output $full 20 2]
    set display [dict get $trunc display]
    list [expr {[dict get $trunc removed_chars] > 0}] [expr {[string first "TRUNCATED_LINES" $display] >= 0}]
} -result {1 1}

test coding_agent_loop-shell-cancel-1.0 {shell cancellation marker} -body {
    set envCmd [::coding_agent_loop::tools::execution_environment_new -type local]
    set output [$envCmd shell [dict create command {sleep 2; printf done} max_ms 50]]
    $envCmd close
    expr {[string first "\[CANCELLED" $output] >= 0}
} -result 1

test coding_agent_loop-session-events-1.0 {session emits required events} -setup {
    set client [::unified_llm::client_new -provider openai -transport ::tests::coding_agent_loop::transport_plain]
    ::unified_llm::set_default_client $client
    set session [::coding_agent_loop::session new -profile openai -env ::coding_agent_loop::default_env]
} -body {
    set _ [$session submit "hello"]
    set events [$session events]
    set types {}
    foreach event $events {
        lappend types [dict get $event type]
    }
    list \
      [expr {[lsearch -exact $types SESSION_START] >= 0}] \
      [expr {[lsearch -exact $types MODEL_REQUEST_START] >= 0}] \
      [expr {[lsearch -exact $types MODEL_REQUEST_END] >= 0}] \
      [expr {[lsearch -exact $types ASSISTANT_TEXT_END] >= 0}] \
      [expr {[lsearch -exact $types TURN_END] >= 0}]
} -cleanup {
    $session close
    $client close
} -result {1 1 1 1 1}

test coding_agent_loop-tool-call-full-output-1.0 {TOOL_CALL_END keeps full output untruncated} -setup {
    set ::tests::coding_agent_loop::call_count 0
    set client [::unified_llm::client_new -provider openai -transport ::tests::coding_agent_loop::transport_tool]
    ::unified_llm::set_default_client $client
    set session [::coding_agent_loop::session new -profile openai -env ::coding_agent_loop::default_env -config [dict create default_tool_char_limit 8 default_tool_line_limit 2]]
} -body {
    set _ [$session submit "run a shell tool"]
    set events [$session events]
    set toolEnd {}
    foreach event $events {
        if {[dict get $event type] eq "TOOL_CALL_END"} {
            set toolEnd $event
        }
    }
    list \
      [expr {[string first "TRUNCATED" [dict get $toolEnd output]] >= 0}] \
      [expr {[string first "line4" [dict get $toolEnd full_output]] >= 0}] \
      [dict get $toolEnd is_error]
} -cleanup {
    $session close
    $client close
} -result {1 1 0}

test coding_agent_loop-profile-1.0 {provider profiles expose expected toolsets} -body {
    set openai [::coding_agent_loop::resolve_profile openai]
    set anthropic [::coding_agent_loop::resolve_profile anthropic]
    set gemini [::coding_agent_loop::resolve_profile gemini]
    list \
      [expr {[lsearch -exact [dict get $openai enabled_tools] apply_patch] >= 0}] \
      [expr {[lsearch -exact [dict get $anthropic enabled_tools] edit_file] >= 0}] \
      [expr {[lsearch -exact [dict get $gemini enabled_tools] edit_file] >= 0}]
} -result {1 1 1}

test coding_agent_loop-openai-system-prompt-parity-1.0 {openai prompt uses codex resources and model-specific variant selection} -setup {
    set session [::coding_agent_loop::session new -profile openai -config [dict create model gpt-5.1]]
} -body {
    set prompt [::coding_agent_loop::__build_system_prompt [$session config]]
    list \
      [expr {[string first "You are GPT-5.1 running in the Codex CLI" $prompt] >= 0}] \
      [expr {[string first "# Environment Context" $prompt] >= 0}] \
      [expr {[string first "workdir parameter" $prompt] >= 0}]
} -cleanup {
    $session close
} -result {1 1 1}

test coding_agent_loop-anthropic-system-prompt-parity-1.0 {anthropic prompt is derived from Claude system sections} -setup {
    set session [::coding_agent_loop::session new -profile anthropic]
} -body {
    set prompt [::coding_agent_loop::__build_system_prompt [$session config]]
    list \
      [expr {[string first "You are Claude Code, Anthropic's official CLI for Claude." $prompt] >= 0}] \
      [expr {[string first "# Tool: Read" $prompt] >= 0}] \
      [expr {[string first "Assistant knowledge cutoff is May 2025." $prompt] >= 0}]
} -cleanup {
    $session close
} -result {1 1 1}

test coding_agent_loop-gemini-system-prompt-parity-1.0 {gemini prompt mirrors Gemini CLI composition and env footer} -setup {
    set session [::coding_agent_loop::session new -profile gemini]
} -body {
    set prompt [::coding_agent_loop::__build_system_prompt [$session config]]
    list \
      [expr {[string first "You are Gemini CLI, an interactive CLI agent" $prompt] >= 0}] \
      [expr {[string first "# Final Reminder" $prompt] >= 0}] \
      [expr {[string first "<env>" $prompt] >= 0}]
} -cleanup {
    $session close
} -result {1 1 1}

test coding_agent_loop-model-config-forwarded-1.0 {session config model is forwarded to unified_llm requests} -setup {
    set ::tests::coding_agent_loop::seen {}
    proc ::tests::coding_agent_loop::transport_model_capture {req} {
        set ::tests::coding_agent_loop::seen $req
        set body [dict create output_text ok usage [dict create input_tokens 1 output_tokens 1 reasoning_tokens 0 cache_read_tokens 0 cache_write_tokens 0]]
        return [dict create status_code 200 headers {} body [::attractor_core::json_encode $body]]
    }
    set client [::unified_llm::client_new -provider openai -transport ::tests::coding_agent_loop::transport_model_capture]
    ::unified_llm::set_default_client $client
    set session [::coding_agent_loop::session new -profile openai -config [dict create model custom-openai-model]]
} -body {
    $session submit "hello"
    dict get [dict get $::tests::coding_agent_loop::seen payload] model
} -cleanup {
    rename ::tests::coding_agent_loop::transport_model_capture {}
    $session close
    $client close
} -result custom-openai-model

test coding_agent_loop-system-prompt-override-1.0 {session config system_prompt overrides generated prompt} -setup {
    set ::tests::coding_agent_loop::seen {}
    proc ::tests::coding_agent_loop::transport_system_prompt_capture {req} {
        set ::tests::coding_agent_loop::seen $req
        set body [dict create output_text ok usage [dict create input_tokens 1 output_tokens 1 reasoning_tokens 0 cache_read_tokens 0 cache_write_tokens 0]]
        return [dict create status_code 200 headers {} body [::attractor_core::json_encode $body]]
    }
    set client [::unified_llm::client_new -provider openai -transport ::tests::coding_agent_loop::transport_system_prompt_capture]
    ::unified_llm::set_default_client $client
    set session [::coding_agent_loop::session new -profile openai -config [dict create system_prompt custom_system_prompt]]
} -body {
    $session submit "hello"
    set input [dict get [dict get $::tests::coding_agent_loop::seen payload] input]
    set firstMessage [lindex $input 0]
    set firstPart [lindex [dict get $firstMessage content] 0]
    dict get $firstPart text
} -cleanup {
    rename ::tests::coding_agent_loop::transport_system_prompt_capture {}
    $session close
    $client close
} -result custom_system_prompt

test coding_agent_loop-steer-injection-1.0 {steer is injected into next model request} -setup {
    set ::tests::coding_agent_loop::seen {}
    proc ::tests::coding_agent_loop::transport_steer {req} {
        dict lappend ::tests::coding_agent_loop::seen requests $req
        set body [dict create output_text ok usage [dict create input_tokens 1 output_tokens 1 reasoning_tokens 0 cache_read_tokens 0 cache_write_tokens 0]]
        return [dict create status_code 200 headers {} body [::attractor_core::json_encode $body]]
    }
    set client [::unified_llm::client_new -provider openai -transport ::tests::coding_agent_loop::transport_steer]
    ::unified_llm::set_default_client $client
    set session [::coding_agent_loop::session new -profile openai]
} -body {
    $session steer "focus on tests"
    $session submit "hello"
    set req [lindex [dict get $::tests::coding_agent_loop::seen requests] 0]
    set messages [dict get $req payload input]
    set userContent [dict get [lindex $messages 1] content]
    set userText [dict get [lindex $userContent 0] text]
    expr {[string first "Steering directives" $userText] >= 0}
} -cleanup {
    rename ::tests::coding_agent_loop::transport_steer {}
    $session close
    $client close
} -result 1

test coding_agent_loop-turn-limit-1.0 {turn limits raise error and emit warning event} -setup {
    set client [::unified_llm::client_new -provider openai -transport ::tests::coding_agent_loop::transport_plain]
    ::unified_llm::set_default_client $client
    set session [::coding_agent_loop::session new -profile openai -config [dict create max_turns 1]]
} -body {
    set _ [$session submit "one"]
    catch {$session submit "two"} err
    set hasTurnLimit 0
    foreach event [$session events] {
        if {[dict get $event type] eq "TURN_LIMIT"} {
            set hasTurnLimit 1
        }
    }
    list [string match "*turn limit reached*" $err] $hasTurnLimit
} -cleanup {
    $session close
    $client close
} -result {1 1}

test coding_agent_loop-unknown-tool-1.0 {unknown tool calls become error tool result and model can continue} -setup {
    set ::tests::coding_agent_loop::call_count 0
    proc ::tests::coding_agent_loop::transport_unknown_tool {req} {
        variable call_count
        incr call_count
        if {$call_count == 1} {
            set body [dict create id first output_text "" tool_calls [list [dict create id t1 name unknown_tool arguments {}]] usage [dict create input_tokens 1 output_tokens 1 reasoning_tokens 0 cache_read_tokens 0 cache_write_tokens 0]]
        } else {
            set payload [dict get $req payload]
            set toolResults [dict get $payload tool_results]
            set body [dict create id second output_text [dict get [lindex $toolResults 0] output] usage [dict create input_tokens 1 output_tokens 1 reasoning_tokens 0 cache_read_tokens 0 cache_write_tokens 0]]
        }
        return [dict create status_code 200 headers {} body [::attractor_core::json_encode $body]]
    }
    set client [::unified_llm::client_new -provider openai -transport ::tests::coding_agent_loop::transport_unknown_tool]
    ::unified_llm::set_default_client $client
    set session [::coding_agent_loop::session new -profile openai]
} -body {
    set response [$session submit "call missing tool"]
    string match "*unknown_tool*" [dict get $response text]
} -cleanup {
    rename ::tests::coding_agent_loop::transport_unknown_tool {}
    $session close
    $client close
} -result 1

test coding_agent_loop-invalid-tool-args-1.0 {invalid tool arguments yield schema_error payload} -setup {
    proc ::tests::coding_agent_loop::transport_bad_args {req} {
        set body [dict create id first output_text "" tool_calls [list [dict create id t1 name read_file arguments {}]] usage [dict create input_tokens 1 output_tokens 1 reasoning_tokens 0 cache_read_tokens 0 cache_write_tokens 0]]
        return [dict create status_code 200 headers {} body [::attractor_core::json_encode $body]]
    }
    set client [::unified_llm::client_new -provider openai -transport ::tests::coding_agent_loop::transport_bad_args]
    ::unified_llm::set_default_client $client
    set session [::coding_agent_loop::session new -profile openai -config [dict create max_tool_rounds_per_input 1]]
} -body {
    catch {$session submit "bad args"} _
    set hasSchemaError 0
    foreach event [$session events] {
        if {[dict get $event type] eq "TOOL_CALL_END" && [dict get $event is_error]} {
            if {[string first "schema_error" [dict get $event full_output]] >= 0} {
                set hasSchemaError 1
            }
        }
    }
    set hasSchemaError
} -cleanup {
    rename ::tests::coding_agent_loop::transport_bad_args {}
    $session close
    $client close
} -result 1

test coding_agent_loop-subagent-depth-limit-1.0 {depth limit prevents recursive spawning} -setup {
    set client [::unified_llm::client_new -provider openai -transport ::tests::coding_agent_loop::transport_plain]
    ::unified_llm::set_default_client $client
    set session [::coding_agent_loop::session new -profile openai -config [dict create max_subagent_depth 1]]
    set sid [dict get [$session config] id]
} -body {
    set toolCall [dict create id tc session_id $sid execution_env_cmd [dict get [$session config] execution_env]]
    set first [::coding_agent_loop::tools::spawn_agent [dict create profile openai] $toolCall]
    set childSession [dict get [dict get $::coding_agent_loop::tools::agents [dict get $first agent_id]] session]
    catch {::coding_agent_loop::tools::spawn_agent [dict create profile openai] [dict create id tc2 session_id $childSession execution_env_cmd [dict get [$session config] execution_env]]} err
    string match "*depth limit*" $err
} -cleanup {
    foreach aid [dict keys $::coding_agent_loop::tools::agents] {
        catch {::coding_agent_loop::tools::close_agent [dict create agent_id $aid] {}}
    }
    $session close
    $client close
} -result 1

test coding_agent_loop-subagent-lifecycle-1.0 {spawn/send/wait/close subagent lifecycle works} -setup {
    set client [::unified_llm::client_new -provider openai -transport ::tests::coding_agent_loop::transport_plain]
    ::unified_llm::set_default_client $client
} -body {
    set spawned [::coding_agent_loop::tools::spawn_agent [dict create profile openai] {}]
    set agentId [dict get $spawned agent_id]
    set sent [::coding_agent_loop::tools::send_input [dict create agent_id $agentId input "hello"] {}]
    set waited [::coding_agent_loop::tools::wait [dict create agent_id $agentId] {}]
    set closed [::coding_agent_loop::tools::close_agent [dict create agent_id $agentId] {}]
    list [dict get $waited state] [dict get $closed state] [string match "ok:*" [dict get $sent text]]
} -cleanup {
    $client close
} -result {complete closed 1}

test coding_agent_loop-abort-1.0 {aborted session rejects further submit} -setup {
    set client [::unified_llm::client_new -provider openai -transport ::tests::coding_agent_loop::transport_plain]
    ::unified_llm::set_default_client $client
    set session [::coding_agent_loop::session new -profile openai]
} -body {
    $session abort
    catch {$session submit "nope"} err
    set types {}
    foreach e [$session events] {
        lappend types [dict get $e type]
    }
    list [string match "*aborted*" $err] [expr {[lsearch -exact $types SESSION_ABORTED] >= 0}]
} -cleanup {
    $session close
    $client close
} -result {1 1}

test coding_agent_loop-loop-detection-1.0 {repeated identical tool patterns trigger loop detection event} -setup {
    set ::tests::coding_agent_loop::call_count 0
    set client [::unified_llm::client_new -provider openai -transport ::tests::coding_agent_loop::transport_tool]
    ::unified_llm::set_default_client $client
    set session [::coding_agent_loop::session new -profile openai]
} -body {
    $session submit "one"
    $session submit "two"
    $session submit "three"
    set hasLoop 0
    foreach event [$session events] {
        if {[dict get $event type] eq "LOOP_DETECTION"} {
            set hasLoop 1
        }
    }
    set hasLoop
} -cleanup {
    $session close
    $client close
} -result 1
