test unified_llm-anthropic-stream-thinking-roundtrip-1.0 {anthropic stream preserves thinking signature and redacted blocks in response content parts} -setup {
    set fixture [::tests::unified_llm_streaming::fixture_path anthropic/anthropic-thinking-signature-redacted.sse]
    set client [::unified_llm::client_new -provider anthropic -transport [list ::tests::unified_llm_streaming::transport_fixture $fixture]]
    set ::tests::unified_llm_streaming::events {}
} -body {
    set result [::unified_llm::stream -client $client -provider anthropic -prompt hi -model claude-sonnet -on_event ::tests::unified_llm_streaming::capture_event]
    set parts [dict get [dict get $result response] content_parts]
    list \
      [dict get [lindex $parts 0] type] \
      [dict get [lindex $parts 0] signature] \
      [dict get [lindex $parts 1] type] \
      [dict get [lindex $parts 1] data]
} -cleanup {
    $client close
    unset -nocomplain ::tests::unified_llm_streaming::events
} -result {thinking sig-stream redacted_thinking opaque-stream}

