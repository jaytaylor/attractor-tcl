    set call [lindex [dict get [dict get $result response] tool_calls] 0]
    list \
      [dict get [dict get $result response] text] \
      [::tests::unified_llm_streaming::has_event_type $::tests::unified_llm_streaming::events REASONING_DELTA] \
      [dict get [dict get [dict get $result response] usage] input_tokens] \
      [dict get [dict get [dict get $result response] usage] output_tokens] \
      [dict get [dict get $call arguments] x]
} -cleanup {
    $client close
    unset -nocomplain ::tests::unified_llm_streaming::events
} -result {Hi 1 5 7 1}

