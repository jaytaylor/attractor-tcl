test unified_llm-stream-middleware-1.0 {stream middleware order and transforms are preserved} -setup {
    set ::tests::unified_llm_streaming::middleware_log {}
    set ::tests::unified_llm_streaming::events {}
    set client [::unified_llm::client_new -provider mock -middlewares [list ::tests::unified_llm_streaming::mw1 ::tests::unified_llm_streaming::mw2]]
} -body {
    set result [::unified_llm::stream -client $client -provider mock -prompt hi -model mock-1 -on_event ::tests::unified_llm_streaming::capture_event]
    set deltaText [::tests::unified_llm_streaming::collect_text_from_deltas $::tests::unified_llm_streaming::events]
    set finishText [dict get [dict get $result response] text]
    set hasEv1 [expr {[lsearch -exact $::tests::unified_llm_streaming::middleware_log ev1] >= 0}]
    set hasEv2 [expr {[lsearch -exact $::tests::unified_llm_streaming::middleware_log ev2] >= 0}]
    list [lrange $::tests::unified_llm_streaming::middleware_log 0 3] [string match "MOCK:*" $deltaText] $hasEv1 $hasEv2 $finishText
} -cleanup {
    $client close
    unset -nocomplain ::tests::unified_llm_streaming::middleware_log
    unset -nocomplain ::tests::unified_llm_streaming::events
} -result {{req1 req2 resp2 resp1} 1 1 1 mock:hi-r2-r1}

test unified_llm-stream-object-expanded-1.0 {stream_object parses buffered JSON after expanded event flow} -setup {
    set fixture [::tests::unified_llm_streaming::fixture_path openai/openai-json-object.sse]
    set client [::unified_llm::client_new -provider openai -transport [list ::tests::unified_llm_streaming::transport_fixture $fixture]]
    set ::tests::unified_llm_streaming::stream_obj {}
    proc ::tests::unified_llm_streaming::capture_obj {obj} {
        set ::tests::unified_llm_streaming::stream_obj $obj
    }
} -body {
    set schema [dict create type object required [list ok n] properties [dict create ok [dict create type boolean] n [dict create type integer]]]
    set _ [::unified_llm::stream_object -client $client -provider openai -prompt x -model gpt-4.1 -schema $schema -on_object ::tests::unified_llm_streaming::capture_obj]
    dict get $::tests::unified_llm_streaming::stream_obj n
} -cleanup {
    rename ::tests::unified_llm_streaming::capture_obj {}
    $client close
    unset -nocomplain ::tests::unified_llm_streaming::stream_obj
} -result 2

test unified_llm-stream-object-invalid-json-2.0 {stream_object invalid JSON returns typed error} -setup {
    set fixture [::tests::unified_llm_streaming::fixture_path openai/openai-invalid-object-json.sse]
    set client [::unified_llm::client_new -provider openai -transport [list ::tests::unified_llm_streaming::transport_fixture $fixture]]
    proc ::tests::unified_llm_streaming::noop_obj {obj} {
        return
    }
} -body {
    set schema [dict create type object required [list ok] properties [dict create ok [dict create type boolean]]]
    catch {::unified_llm::stream_object -client $client -provider openai -prompt x -model gpt-4.1 -schema $schema -on_object ::tests::unified_llm_streaming::noop_obj} err opts
    dict get $opts -errorcode
} -cleanup {
    rename ::tests::unified_llm_streaming::noop_obj {}
    $client close
} -result {UNIFIED_LLM OBJECT INVALID_JSON}

test unified_llm-stream-object-stream-error-1.0 {stream_object returns STREAM_ERROR when stream terminates with ERROR} -setup {
    set fixture [::tests::unified_llm_streaming::fixture_path malformed/openai-invalid-json-after-partial.sse]
    set client [::unified_llm::client_new -provider openai -transport [list ::tests::unified_llm_streaming::transport_fixture $fixture]]
    proc ::tests::unified_llm_streaming::noop_obj_2 {obj} {
        return
    }
} -body {
    catch {::unified_llm::stream_object -client $client -provider openai -prompt x -model gpt-4.1 -on_object ::tests::unified_llm_streaming::noop_obj_2} err opts
    dict get $opts -errorcode
} -cleanup {
    rename ::tests::unified_llm_streaming::noop_obj_2 {}
    $client close
} -result {UNIFIED_LLM OBJECT STREAM_ERROR}

test unified_llm-stream-no-retry-after-partial-1.0 {stream does not retry transport after partial data then error} -setup {
    set ::tests::unified_llm_streaming::call_count 0
    set ::tests::unified_llm_streaming::events {}
    set fixture [::tests::unified_llm_streaming::fixture_path malformed/openai-invalid-json-after-partial.sse]
    proc ::tests::unified_llm_streaming::transport_counting {fixture req} {
        incr ::tests::unified_llm_streaming::call_count
        return [dict create status_code 200 headers {} body [::tests::unified_llm_streaming::read_file $fixture]]
    }
    set client [::unified_llm::client_new -provider openai -transport [list ::tests::unified_llm_streaming::transport_counting $fixture]]
} -body {
    set _ [::unified_llm::stream -client $client -provider openai -prompt hi -model gpt-4.1 -on_event ::tests::unified_llm_streaming::capture_event]
    list $::tests::unified_llm_streaming::call_count [dict get [lindex $::tests::unified_llm_streaming::events end] type]
} -cleanup {
    rename ::tests::unified_llm_streaming::transport_counting {}
    $client close
    unset -nocomplain ::tests::unified_llm_streaming::call_count
    unset -nocomplain ::tests::unified_llm_streaming::events
} -result {1 ERROR}
