test unified_llm-openai-stream-translation-tool-1.0 {openai tool-call deltas are assembled and decoded} -setup {
    set fixture [::tests::unified_llm_streaming::fixture_path openai/openai-tool-call.sse]
    set client [::unified_llm::client_new -provider openai -transport [list ::tests::unified_llm_streaming::transport_fixture $fixture]]
    set ::tests::unified_llm_streaming::events {}
} -body {
    set result [::unified_llm::stream -client $client -provider openai -prompt hi -model gpt-4.1 -on_event ::tests::unified_llm_streaming::capture_event]
    set call [lindex [dict get [dict get $result response] tool_calls] 0]
    list \
      [::tests::unified_llm_streaming::has_event_type $::tests::unified_llm_streaming::events TOOL_CALL_START] \
      [::tests::unified_llm_streaming::has_event_type $::tests::unified_llm_streaming::events TOOL_CALL_DELTA] \
      [::tests::unified_llm_streaming::has_event_type $::tests::unified_llm_streaming::events TOOL_CALL_END] \
      [dict get $call name] \
      [dict get [dict get $call arguments] x]
} -cleanup {
    $client close
    unset -nocomplain ::tests::unified_llm_streaming::events
} -result {1 1 1 calc 1}

