package require tcltest
namespace import ::tcltest::*

set root [file normalize [file join [file dirname [info script]] .. ..]]
lappend auto_path $root
package require unified_llm
package require attractor_core

namespace eval ::tests::unified_llm_streaming {
    variable events {}
    variable call_count 0
    variable middleware_log {}
}

proc ::tests::unified_llm_streaming::fixture_path {rel} {
    set root [file normalize [file join [file dirname [info script]] .. ..]]
    return [file join $root tests fixtures unified_llm_streaming {*}[split $rel /]]
}

proc ::tests::unified_llm_streaming::read_file {path} {
    set fh [open $path r]
    set data [read $fh]
    close $fh
    return $data
}

proc ::tests::unified_llm_streaming::transport_fixture {fixture req} {
    set body [::tests::unified_llm_streaming::read_file $fixture]
    return [dict create status_code 200 headers {} body $body]
}

proc ::tests::unified_llm_streaming::capture_event {event} {
    variable events
    lappend events $event
}

proc ::tests::unified_llm_streaming::has_event_type {events targetType} {
    foreach event $events {
        if {[dict get $event type] eq $targetType} {
            return 1
        }
    }
    return 0
}

proc ::tests::unified_llm_streaming::collect_text_from_deltas {events} {
    set out ""
    foreach event $events {
        if {[dict get $event type] eq "TEXT_DELTA" && [dict exists $event delta]} {
            append out [dict get $event delta]
        }
    }
    return $out
}

proc ::tests::unified_llm_streaming::mw1 {phase payload} {
    variable middleware_log
    switch -- $phase {
        request {
            lappend middleware_log req1
            return $payload
        }
        event {
            lappend middleware_log ev1
            if {[dict get $payload type] eq "TEXT_DELTA"} {
                dict set payload delta [string toupper [dict get $payload delta]]
            }
            return $payload
        }
        response {
            lappend middleware_log resp1
            dict set payload text "[dict get $payload text]-r1"
            return $payload
        }
    }
    return $payload
}

proc ::tests::unified_llm_streaming::mw2 {phase payload} {
    variable middleware_log
    switch -- $phase {
        request {
            lappend middleware_log req2
            return $payload
        }
        event {
            lappend middleware_log ev2
            return $payload
        }
        response {
            lappend middleware_log resp2
            dict set payload text "[dict get $payload text]-r2"
            return $payload
        }
    }
    return $payload
}

test unified_llm-stream-fixture-load-1.0 {stream fixtures exist and are readable} -body {
    set p [::tests::unified_llm_streaming::fixture_path openai/openai-text.sse]
    set payload [::tests::unified_llm_streaming::read_file $p]
    list [file exists $p] [string match "*response.output_text.delta*" $payload]
} -result {1 1}

test unified_llm-stream-event-model-1.0 {synthetic stream follows start/delta/end contract} -setup {
    set client [::unified_llm::client_new -provider mock]
    set ::tests::unified_llm_streaming::events {}
} -body {
    ::unified_llm::stream -client $client -provider mock -prompt hello -model mock-1 -on_event ::tests::unified_llm_streaming::capture_event
    set types {}
    foreach event $::tests::unified_llm_streaming::events {
        lappend types [dict get $event type]
    }
    list [lindex $types 0] [lindex $types 1] [lindex $types end-1] [lindex $types end]
} -cleanup {
    $client close
    unset -nocomplain ::tests::unified_llm_streaming::events
} -result {STREAM_START TEXT_START TEXT_END FINISH}

test unified_llm-stream-events-concatenate-1.0 {text deltas concatenate to FINISH response text} -setup {
    set fixture [::tests::unified_llm_streaming::fixture_path openai/openai-text.sse]
    set client [::unified_llm::client_new -provider openai -transport [list ::tests::unified_llm_streaming::transport_fixture $fixture]]
    set ::tests::unified_llm_streaming::events {}
} -body {
    set result [::unified_llm::stream -client $client -provider openai -prompt x -model gpt-4.1 -on_event ::tests::unified_llm_streaming::capture_event]
    set collected [::tests::unified_llm_streaming::collect_text_from_deltas $::tests::unified_llm_streaming::events]
    set finishedText [dict get [dict get $result response] text]
    list $collected $finishedText
} -cleanup {
    $client close
    unset -nocomplain ::tests::unified_llm_streaming::events
} -result {Hello Hello}

test unified_llm-stream-error-invalid-json-1.0 {malformed stream JSON emits ERROR and no FINISH} -setup {
    set fixture [::tests::unified_llm_streaming::fixture_path malformed/openai-invalid-json-after-partial.sse]
    set client [::unified_llm::client_new -provider openai -transport [list ::tests::unified_llm_streaming::transport_fixture $fixture]]
    set ::tests::unified_llm_streaming::events {}
} -body {
    set _ [::unified_llm::stream -client $client -provider openai -prompt x -model gpt-4.1 -on_event ::tests::unified_llm_streaming::capture_event]
    set hasFinish [::tests::unified_llm_streaming::has_event_type $::tests::unified_llm_streaming::events FINISH]
    list [dict get [lindex $::tests::unified_llm_streaming::events end] type] $hasFinish
} -cleanup {
    $client close
    unset -nocomplain ::tests::unified_llm_streaming::events
} -result {ERROR 0}

test unified_llm-openai-stream-translation-text-1.0 {openai text stream maps to unified events and usage} -setup {
    set fixture [::tests::unified_llm_streaming::fixture_path openai/openai-text.sse]
    set client [::unified_llm::client_new -provider openai -transport [list ::tests::unified_llm_streaming::transport_fixture $fixture]]
    set ::tests::unified_llm_streaming::events {}
} -body {
    set result [::unified_llm::stream -client $client -provider openai -prompt hi -model gpt-4.1 -on_event ::tests::unified_llm_streaming::capture_event]
    list \
      [::tests::unified_llm_streaming::has_event_type $::tests::unified_llm_streaming::events TEXT_START] \
      [::tests::unified_llm_streaming::has_event_type $::tests::unified_llm_streaming::events TEXT_END] \
      [dict get [dict get $result response] text] \
      [dict get [dict get [dict get $result response] usage] reasoning_tokens]
} -cleanup {
    $client close
    unset -nocomplain ::tests::unified_llm_streaming::events
} -result {1 1 Hello 1}

