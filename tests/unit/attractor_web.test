package require tcltest
namespace import ::tcltest::*

set root [file normalize [file join [file dirname [info script]] .. ..]]
lappend auto_path $root
package require attractor_web


test attractor_web-normalize-dot-source-1.0 {raw dot source is preserved} -body {
    ::attractor_web::normalize_dot_source {digraph x { start [shape=Mdiamond]; exit [shape=Msquare]; start -> exit; }}
} -result {digraph x { start [shape=Mdiamond]; exit [shape=Msquare]; start -> exit; }}

test attractor_web-normalize-dot-source-2.0 {markdown fenced dot source is stripped} -body {
    ::attractor_web::normalize_dot_source {```dot
digraph x { start [shape=Mdiamond]; exit [shape=Msquare]; start -> exit; }
```}
} -result {digraph x { start [shape=Mdiamond]; exit [shape=Msquare]; start -> exit; }}

test attractor_web-extract-svg-markup-1.0 {svg extraction trims non-svg noise and returns svg block only} -body {
    set payload "warning: ignored\n<?xml version=\"1.0\"?>\n<svg><g><text>ok</text></g></svg>\ntrailer"
    ::attractor_web::__extract_svg_markup $payload
} -result {<svg><g><text>ok</text></g></svg>}

test attractor_web-extract-svg-markup-2.0 {non-svg payload yields empty string} -body {
    ::attractor_web::__extract_svg_markup {digraph x { start -> exit; }}
} -result {}

test attractor_web-filename-validation-1.0 {filename validation enforces leaf-only names} -body {
    list \
      [::attractor_web::__filename_valid "flow.dot"] \
      [::attractor_web::__filename_valid "../flow.dot"] \
      [::attractor_web::__filename_valid "dir/flow.dot"] \
      [::attractor_web::__filename_valid "dir\\flow.dot"]
} -result {1 0 0 0}

test attractor_web-id-validation-1.0 {run and node ids enforce allowlist patterns} -body {
    list \
      [::attractor_web::__run_id_valid "run-123-1"] \
      [::attractor_web::__run_id_valid "../run-123"] \
      [::attractor_web::__node_id_valid "build_stage"] \
      [::attractor_web::__node_id_valid "build-stage"]
} -result {1 0 1 0}

test attractor_web-dashboard-template-1.0 {dashboard html contains expected markers} -body {
    set html [::attractor_web::__html_dashboard]
    list \
      [expr {[string first "Attractor Web Dashboard" $html] >= 0}] \
      [expr {[string first "EventSource('/events')" $html] >= 0}] \
      [expr {[string first "Generate DOT" $html] >= 0}] \
      [expr {[string first "/api/v1/dot/generate/stream" $html] >= 0}] \
      [expr {[string first "Preview DOT" $html] >= 0}]
} -result {1 1 1 1 1}

test attractor_web-dot-user-prompt-1.0 {dot stream payload validation enforces required fields} -body {
    list \
      [catch {::attractor_web::__dot_user_prompt generate {}}] \
      [catch {::attractor_web::__dot_user_prompt fix [dict create dotSource "digraph x { }"]}] \
      [catch {::attractor_web::__dot_user_prompt iterate [dict create baseDot "digraph x { }"]}]
} -result {1 1 1}

test attractor_web-dot-model-defaults-1.0 {dot model defaults map per provider} -body {
    list \
      [::attractor_web::__dot_model_default openai] \
      [::attractor_web::__dot_model_default anthropic] \
      [::attractor_web::__dot_model_default gemini]
} -result {gpt-5.2 claude-haiku-4-5 gemini-3-flash-preview}

test attractor_web-dot-system-prompt-validation-1.0 {generate system prompt enforces validation and retry routing concepts} -body {
    set prompt [string tolower [::attractor_web::__dot_system_prompt]]
    list \
      [expr {[string first "validation-first requirements" $prompt] >= 0}] \
      [expr {[string first "goal_gate=true" $prompt] >= 0}] \
      [expr {[string first "retry_target" $prompt] >= 0}] \
      [expr {[string first "success -> exit" $prompt] >= 0}] \
      [expr {[string first "retry -> implementation or planning stage" $prompt] >= 0}]
} -result {1 1 1 1 1}

test attractor_web-dot-user-prompt-generate-validation-1.0 {generate user prompt appends validation-loop requirements} -body {
    set prompt [string tolower [::attractor_web::__dot_user_prompt generate [dict create prompt "build me a pipeline"]]]
    list \
      [expr {[string first "mandatory workflow requirements" $prompt] >= 0}] \
      [expr {[string first "validation must verify work against requirements" $prompt] >= 0}] \
      [expr {[string first "kick rework to planning or implementation" $prompt] >= 0}]
} -result {1 1 1}
