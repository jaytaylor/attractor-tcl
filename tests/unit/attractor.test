package require tcltest
namespace import ::tcltest::*

set root [file normalize [file join [file dirname [info script]] .. ..]]
lappend auto_path $root
package require attractor
package require attractor_core

namespace eval ::tests::attractor {}

proc ::tests::attractor::backend {request} {
    set nodeId [dict get $request node_id]
    if {$nodeId eq "build"} {
        return [dict create text "build complete" preferred_label success context_updates [dict create goal done]]
    }
    return [dict create text "ok"]
}

proc ::tests::attractor::verify_loop_backend {request} {
    variable verify_calls
    set nodeId [dict get $request node_id]
    if {$nodeId eq "draft_artifact"} {
        return [dict create text "```svg\n<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 120 80\"><circle cx=\"30\" cy=\"45\" r=\"10\"/><rect x=\"40\" y=\"35\" width=\"60\" height=\"20\"/></svg>\n```"]
    }
    if {$nodeId eq "verify_artifact"} {
        incr verify_calls
        if {$verify_calls == 1} {
            return [dict create text "outcome=retry\nlegs look incomplete"]
        }
        return [dict create text "outcome=success\ndog is recognizable and valid svg"]
    }
    return [dict create text "ok"]
}

proc ::tests::attractor::event_sink {event} {
    variable events
    lappend events $event
}

test attractor-parse-validate-1.0 {parse and validate simple graph} -body {
    set dot {
        digraph demo {
            start [shape=Mdiamond];
            build [handler=codergen, prompt="do build"];
            exit [shape=Msquare];
            start -> build;
            build -> exit [label=success, weight=10];
        }
    }
    set graph [::attractor::parse_dot $dot]
    set diagnostics [::attractor::validate $graph]
    list [dict get $graph id] [llength [dict get $graph edges]] [::attractor::__has_validation_errors $diagnostics]
} -result {demo 2 0}

test attractor-parse-chained-multiline-1.0 {parser handles chained edges and multiline attrs} -body {
    set graph [::attractor::parse_dot {
        digraph demo {
            node [class="core"];
            start [shape=Mdiamond];
            build [
                handler=codergen,
                prompt="run"
            ];
            exit [shape=Msquare];
            start -> build -> exit [label=success];
        }
    }]
    list [llength [dict get $graph edges]] [dict get [dict get $graph nodes build attrs] class]
} -result {2 core}

test attractor-validation-rules-1.0 {validation catches missing start/exit and edge errors} -body {
    set graph [::attractor::parse_dot {
        digraph bad {
            a [handler=codergen];
            b [handler=codergen];
            a -> c;
        }
    }]
    set diagnostics [::attractor::validate $graph]
    set rules {}
    foreach d $diagnostics {
        lappend rules [dict get $d rule]
    }
    list [expr {[lsearch -exact $rules validation.start.required] >= 0}] [expr {[lsearch -exact $rules validation.exit.required] >= 0}] [expr {[lsearch -exact $rules validation.edge.to_unknown] >= 0}]
} -result {1 1 1}

test attractor-validation-node-id-1.0 {validation rejects node ids that are not bare identifiers} -body {
    set graph [::attractor::parse_dot {
        digraph badid {
            start [shape=Mdiamond];
            "bad-id" [handler=codergen];
            exit [shape=Msquare];
            start -> "bad-id";
            "bad-id" -> exit;
        }
    }]
    set diagnostics [::attractor::validate $graph]
    set hit 0
    foreach d $diagnostics {
        if {[dict get $d rule] eq "validation.node_id.invalid"} {
            set hit 1
        }
    }
    set hit
} -result 1

test attractor-reachability-warning-1.0 {unreachable node emits warning metadata} -body {
    set graph [::attractor::parse_dot {
        digraph warn {
            start [shape=Mdiamond];
            build [handler=codergen];
            exit [shape=Msquare];
            orphan [handler=codergen];
            start -> build;
            build -> exit;
        }
    }]
    set diagnostics [::attractor::validate $graph]
    set hasWarn 0
    foreach d $diagnostics {
        if {[dict get $d severity] eq "warning" && [dict get $d rule] eq "validation.node.unreachable"} {
            set hasWarn 1
        }
    }
    set hasWarn
} -result 1

test attractor-condition-1.0 {condition evaluator supports = != && and context.*} -body {
    set context [dict create branch left x 1]
    list \
      [::attractor::__condition_matches {branch=left && context.x=1} $context success ok] \
      [::attractor::__condition_matches {preferred_label=ok} $context success ok] \
      [::attractor::__condition_matches {outcome!=failed} $context success ok] \
      [::attractor::__condition_matches {branch=right} $context success ok] \
      [::attractor::__condition_matches {outcome=retry} $context success retry]
} -result {1 1 1 0 1}

test attractor-run-verify-loop-and-svg-artifact-1.0 {run routes retry loops by outcome label, injects prior artifact for verification, and persists svg artifact} -setup {
    set logsRoot [file join $root .scratch verification SPRINT-008 attractor verify-loop-[pid]]
    file delete -force $logsRoot
    namespace eval ::tests::attractor { variable verify_calls 0 }
    set graph [::attractor::parse_dot {
        digraph verify_loop {
            start [shape=Mdiamond];
            draft_artifact [handler=codergen, prompt="Draft svg dog."];
            verify_artifact [handler=codergen, goal_gate=true, prompt="Verify the artifact and return outcome=success or outcome=retry."];
            exit [shape=Msquare];
            start -> draft_artifact;
            draft_artifact -> verify_artifact;
            verify_artifact -> draft_artifact [condition="outcome=retry", label=retry];
            verify_artifact -> exit [condition="outcome=success", label=success];
        }
    }]
} -body {
    set result [::attractor::run $graph -backend ::tests::attractor::verify_loop_backend -logs_root $logsRoot]
    set verifyPromptPath [file join $logsRoot verify_artifact prompt.md]
    set fh [open $verifyPromptPath r]
    set verifyPrompt [read $fh]
    close $fh
    set svgPath [file join $logsRoot artifacts draft_artifact.svg]
    list \
      [dict get $result status] \
      $::tests::attractor::verify_calls \
      [file exists $svgPath] \
      [expr {[string first "<svg" $verifyPrompt] >= 0}]
} -cleanup {
    file delete -force $logsRoot
    namespace eval ::tests::attractor { unset -nocomplain verify_calls }
} -result {success 2 1 1}

test attractor-style-apply-1.0 {model stylesheet applies by specificity} -body {
    set graph [::attractor::parse_dot {
        digraph s {
            start [shape=Mdiamond, class="entry"];
            build [handler=codergen, class="entry"];
            exit [shape=Msquare];
            start -> build;
            build -> exit;
        }
    }]
    set rules [::attractor::parse_stylesheet {
        .entry { temperature=0.2 };
        #build { temperature=0.7 };
    }]
    set styled [::attractor::apply_stylesheet $graph $rules]
    list [dict get [dict get $styled nodes start attrs] temperature] [dict get [dict get $styled nodes build attrs] temperature]
} -result {0.2 0.7}

test attractor-handler-wait-human-1.0 {wait.human routes using queue interviewer choices} -setup {
    set queue [::attractor::interviewer::queue_new [list reject]]
    set logsRoot [file join $root .scratch verification SPRINT-003 attractor wait-human-[pid]]
    file delete -force $logsRoot
    set graph [::attractor::parse_dot {
        digraph demo {
            start [shape=Mdiamond];
            ask [type="wait.human", question="Proceed?"];
            done [handler=codergen];
            reject_node [handler=codergen];
            exit [shape=Msquare];
            start -> ask;
            ask -> done [label=approve];
            ask -> reject_node [label=reject];
            done -> exit;
            reject_node -> exit;
        }
    }]
} -body {
    set result [::attractor::run $graph -backend ::tests::attractor::backend -interviewer $queue -logs_root $logsRoot]
    list [dict get $result status] [lsearch -exact [dict get $result completed_nodes] reject_node]
} -cleanup {
    file delete -force $logsRoot
} -result {success 2}

test attractor-run-artifacts-1.0 {run creates checkpoint and node artifacts} -setup {
    set logsRoot [file join $root .scratch verification SPRINT-003 attractor test-run-[pid]]
    file delete -force $logsRoot
    set dot {
        digraph demo {
            start [shape=Mdiamond];
            build [handler=codergen, prompt="goal=$goal"];
            exit [shape=Msquare];
            start -> build;
            build -> exit [label=success, weight=10];
        }
    }
    set graph [::attractor::parse_dot $dot]
} -body {
    set result [::attractor::run $graph -backend ::tests::attractor::backend -logs_root $logsRoot]
    list \
      [dict get $result status] \
      [file exists [file join $logsRoot checkpoint.json]] \
      [file exists [file join $logsRoot build status.json]] \
      [file exists [file join $logsRoot build prompt.md]] \
      [file exists [file join $logsRoot build response.md]]
} -cleanup {
    file delete -force $logsRoot
} -result {success 1 1 1 1}

test attractor-run-event-hook-1.0 {run emits deterministic lifecycle events when callback is configured} -setup {
    set logsRoot [file join $root .scratch verification SPRINT-008 attractor event-hook-[pid]]
    file delete -force $logsRoot
    namespace eval ::tests::attractor { variable events {} }
    set graph [::attractor::parse_dot {
        digraph evented {
            start [shape=Mdiamond];
            build [handler=codergen, prompt="build"];
            exit [shape=Msquare];
            start -> build;
            build -> exit [label=success, weight=1];
        }
    }]
} -body {
    set result [::attractor::run $graph \
        -backend ::tests::attractor::backend \
        -logs_root $logsRoot \
        -run_id run-test \
        -on_event ::tests::attractor::event_sink]
    set eventTypes {}
    set seqs {}
    foreach e $::tests::attractor::events {
        lappend eventTypes [dict get $e type]
        lappend seqs [dict get $e seq]
    }
    list \
      [dict get $result status] \
      [lindex $eventTypes 0] \
      [lindex $eventTypes end] \
      [expr {[lsort -integer $seqs] eq $seqs}] \
      [expr {[lsearch -exact $eventTypes StageStarted] >= 0}] \
      [expr {[lsearch -exact $eventTypes StageCompleted] >= 0}] \
      [expr {[lsearch -exact $eventTypes CheckpointSaved] >= 0}]
} -cleanup {
    file delete -force $logsRoot
    namespace eval ::tests::attractor { unset -nocomplain events }
} -result {success PipelineStarted PipelineCompleted 1 1 1 1}

test attractor-edge-selection-1.0 {edge selection uses label then weight} -body {
    set edges [list \
      [dict create from a to b attrs [dict create label x weight 1]] \
      [dict create from a to c attrs [dict create label y weight 99]] \
      [dict create from a to d attrs [dict create label x weight 2]]]
    set outcome [dict create preferred_label x suggested_next_ids {} status success]
    set selected [::attractor::__select_next_edge $edges $outcome {}]
    dict get $selected to
} -result d

test attractor-resume-1.0 {resume starts from checkpoint node} -setup {
    set logsRoot [file join $root .scratch verification SPRINT-003 attractor test-resume-[pid]]
    file delete -force $logsRoot
    file mkdir $logsRoot
    ::attractor::__write_json_file [file join $logsRoot checkpoint.json] [dict create timestamp now current_node build completed_nodes {start} node_retries {} context_values {}]
    set dot {
        digraph demo {
            start [shape=Mdiamond];
            build [handler=codergen, prompt="build now"];
            exit [shape=Msquare];
            start -> build;
            build -> exit [label=success, weight=1];
        }
    }
    set graph [::attractor::parse_dot $dot]
} -body {
    set result [::attractor::run $graph -backend ::tests::attractor::backend -logs_root $logsRoot -resume 1]
    list [dict get $result status] [lsearch -exact [dict get $result completed_nodes] build]
} -cleanup {
    file delete -force $logsRoot
} -result {success 1}

test attractor-custom-handler-1.0 {custom handlers can be registered and executed} -setup {
    proc ::tests::attractor::custom_handler {request} {
        return [dict create status success preferred_label ok suggested_next_ids {} context_updates {} notes custom terminal 0]
    }
    ::attractor::register_handler custom.node ::tests::attractor::custom_handler
    set graph [::attractor::parse_dot {
        digraph c {
            start [shape=Mdiamond];
            mid [type="custom.node"];
            exit [shape=Msquare];
            start -> mid;
            mid -> exit [label=ok];
        }
    }]
} -body {
    set result [::attractor::run $graph -backend ::tests::attractor::backend -logs_root [file join $root .scratch verification SPRINT-003 attractor custom-[pid]]]
    dict get $result status
} -cleanup {
    ::attractor::clear_handlers
    rename ::tests::attractor::custom_handler {}
} -result success

test attractor-handler-shape-mapping-1.0 {canonical shape mapping resolves expected handlers} -body {
    list \
      [::attractor::__handler_from_node n [dict create shape Mdiamond] start exit] \
      [::attractor::__handler_from_node n [dict create shape Msquare] start exit] \
      [::attractor::__handler_from_node n [dict create shape diamond] start exit] \
      [::attractor::__handler_from_node n [dict create shape box] start exit] \
      [::attractor::__handler_from_node n [dict create shape hexagon] start exit] \
      [::attractor::__handler_from_node n [dict create shape parallelogram] start exit] \
      [::attractor::__handler_from_node n [dict create shape component] start exit] \
      [::attractor::__handler_from_node n [dict create shape tripleoctagon] start exit] \
      [::attractor::__handler_from_node n [dict create shape house] start exit] \
      [::attractor::__handler_from_node n [dict create shape triangle] start exit]
} -result {start exit conditional codergen wait.human tool parallel parallel.fan_in stack.manager_loop codergen}

test attractor-handler-shape-type-override-1.0 {type overrides shape mapping and unknown shape falls back} -body {
    list \
      [::attractor::__handler_from_node n [dict create type tool shape hexagon] start exit] \
      [::attractor::__handler_from_node n [dict create type parallel.fan_in shape triangle] start exit] \
      [::attractor::__handler_from_node n [dict create shape unknown] start exit]
} -result {tool parallel.fan_in codergen}

test attractor-handler-parallel-fan-in-alias-1.0 {parallel.fan_in and legacy fan-in execute the same handler} -body {
    set base [list node [dict create] [dict create] ::tests::attractor::backend ::attractor::default_interviewer {} [file join $root .scratch verification SPRINT-006 attractor fan-in-[pid]] {}]
    set canonical [::attractor::__execute_handler parallel.fan_in {*}$base]
    set legacy [::attractor::__execute_handler fan-in {*}$base]
    list [dict get $canonical status] [dict get $canonical notes] [dict get $legacy status] [dict get $legacy notes]
} -result {success fan-in success fan-in}
