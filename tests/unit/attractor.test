package require tcltest
namespace import ::tcltest::*

set root [file normalize [file join [file dirname [info script]] .. ..]]
lappend auto_path $root
package require attractor
package require attractor_core

namespace eval ::tests::attractor {}

proc ::tests::attractor::backend {request} {
    set nodeId [dict get $request node_id]
    if {$nodeId eq "build"} {
        return [dict create text "build complete" preferred_label success]
    }
    return [dict create text "ok"]
}

test attractor-parse-validate-1.0 {parse and validate simple graph} -body {
    set dot {
        digraph demo {
            start [shape=start];
            build [handler=codergen, prompt="do build"];
            exit [shape=doublecircle];
            start -> build;
            build -> exit [label=success, weight=10];
        }
    }
    set graph [::attractor::parse_dot $dot]
    set diagnostics [::attractor::validate $graph]
    list [dict get $graph id] [llength [dict get $graph edges]] [llength $diagnostics]
} -result {demo 2 0}

test attractor-run-artifacts-1.0 {run creates checkpoint and node artifacts} -setup {
    set logsRoot [file join $root .scratch verification SPRINT-001 attractor test-run-[pid]]
    file delete -force $logsRoot
    set dot {
        digraph demo {
            start [shape=start];
            build [handler=codergen, prompt="build now"];
            exit [shape=doublecircle];
            start -> build;
            build -> exit [label=success, weight=10];
        }
    }
    set graph [::attractor::parse_dot $dot]
} -body {
    set result [::attractor::run $graph -backend ::tests::attractor::backend -logs_root $logsRoot]
    list \
      [dict get $result status] \
      [file exists [file join $logsRoot checkpoint.json]] \
      [file exists [file join $logsRoot build status.json]] \
      [file exists [file join $logsRoot build prompt.md]] \
      [file exists [file join $logsRoot build response.md]]
} -cleanup {
    file delete -force $logsRoot
} -result {success 1 1 1 1}

test attractor-edge-selection-1.0 {edge selection uses label then weight} -body {
    set edges [list \
      [dict create from a to b attrs [dict create label x weight 1]] \
      [dict create from a to c attrs [dict create label y weight 99]] \
      [dict create from a to d attrs [dict create label x weight 2]]]
    set outcome [dict create preferred_label x suggested_next_ids {}]
    set selected [::attractor::__select_next_edge $edges $outcome {}]
    dict get $selected to
} -result d

test attractor-resume-1.0 {resume starts from checkpoint node} -setup {
    set logsRoot [file join $root .scratch verification SPRINT-001 attractor test-resume-[pid]]
    file delete -force $logsRoot
    file mkdir $logsRoot
    ::attractor::__write_json_file [file join $logsRoot checkpoint.json] [dict create timestamp now current_node build completed_nodes {start} node_retries {} context_values {}]
    set dot {
        digraph demo {
            start [shape=start];
            build [handler=codergen, prompt="build now"];
            exit [shape=doublecircle];
            start -> build;
            build -> exit [label=success, weight=1];
        }
    }
    set graph [::attractor::parse_dot $dot]
} -body {
    set result [::attractor::run $graph -backend ::tests::attractor::backend -logs_root $logsRoot -resume 1]
    list [dict get $result status] [lsearch -exact [dict get $result completed_nodes] build]
} -cleanup {
    file delete -force $logsRoot
} -result {success 1}

test attractor-validate-start-exit-1.0 {start incoming and exit outgoing edges are rejected} -body {
    set graph [::attractor::parse_dot {
        digraph bad {
            start [shape=start];
            middle [handler=codergen];
            exit [shape=doublecircle];
            middle -> start;
            exit -> middle;
        }
    }]
    set diagnostics [::attractor::validate $graph]
    set codes {}
    foreach d $diagnostics {
        lappend codes [dict get $d code]
    }
    list [expr {[lsearch -exact $codes start_incoming] >= 0}] [expr {[lsearch -exact $codes exit_outgoing] >= 0}]
} -result {1 1}

test attractor-condition-1.0 {condition evaluator supports equality and inequality} -body {
    set context [dict create branch left]
    list \
      [::attractor::__condition_matches {branch == left} $context] \
      [::attractor::__condition_matches {branch != right} $context] \
      [::attractor::__condition_matches {branch == right} $context]
} -result {1 1 0}

test attractor-tool-handler-1.0 {tool handler runs command and fails when command missing} -body {
    set success [::attractor::__execute_handler tool n1 [dict create tool_command {printf done}] {} ::attractor::default_codergen_backend ::attractor::default_interviewer [file join $root .scratch]]
    set failed [::attractor::__execute_handler tool n2 {} {} ::attractor::default_codergen_backend ::attractor::default_interviewer [file join $root .scratch]]
    list [dict get $success status] [dict get $failed failure_reason]
} -result {success missing_tool_command}

test attractor-handler-wait-human-1.0 {wait.human handler consults interviewer decision} -setup {
    proc ::tests::attractor::reject_interviewer {request} {
        return [dict create approved 0 response denied]
    }
} -body {
    set outcome [::attractor::__execute_handler wait.human ask [dict create question "Proceed?"] {} ::attractor::default_codergen_backend ::tests::attractor::reject_interviewer [file join $root .scratch]]
    list [dict get $outcome status] [dict get $outcome failure_reason]
} -cleanup {
    rename ::tests::attractor::reject_interviewer {}
} -result {failed rejected}

test attractor-parse-comments-subgraph-1.0 {parser strips comments and flattens subgraphs} -body {
    set graph [::attractor::parse_dot {
        digraph demo {
            // comment
            start [shape=start];
            subgraph cluster_a { build [handler=codergen]; }
            exit [shape=doublecircle];
            start -> build; # inline comment
            build -> exit;
        }
    }]
    list [dict exists [dict get $graph nodes] build] [llength [dict get $graph edges]]
} -result {1 2}
