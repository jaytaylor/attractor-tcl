test unified_llm-from-env-google-api-key-alias-1.0 {from_env discovers Gemini from GOOGLE_API_KEY when GEMINI_API_KEY is unset} -setup {
    unset -nocomplain ::env(OPENAI_API_KEY) ::env(ANTHROPIC_API_KEY) ::env(GEMINI_API_KEY)
    set ::env(GOOGLE_API_KEY) google-key
    unset -nocomplain ::env(UNIFIED_LLM_PROVIDER)
} -body {
    set client [::unified_llm::from_env]
    set cfg [$client config]
    set out [list [dict get $cfg default_provider] [dict get [dict get $cfg providers gemini] api_key]]
    $client close
    set out
} -cleanup {
    unset -nocomplain ::env(OPENAI_API_KEY) ::env(ANTHROPIC_API_KEY) ::env(GEMINI_API_KEY) ::env(GOOGLE_API_KEY) ::env(UNIFIED_LLM_PROVIDER)
} -result {gemini google-key}

test unified_llm-provider-metadata-usage-1.0 {adapters map metadata headers and usage fields} -setup {
    proc ::tests::unified_llm::transport_metadata {req} {
        set provider [dict get $req provider]
        switch -- $provider {
            openai {
                set body [dict create output_text openai usage [dict create input_tokens 3 output_tokens 5 output_tokens_details [dict create reasoning_tokens 2] input_tokens_details [dict create cached_tokens 7] cache_creation_tokens 4]]
                set headers [dict create x-request-id req-openai openai-processing-ms 11]
            }
            anthropic {
                set body [dict create content [list [dict create type text text anthropic]] usage [dict create input_tokens 2 output_tokens 4 cache_read_input_tokens 6 cache_creation_input_tokens 3]]
                set headers [dict create request-id req-anthropic]
            }
            gemini {
                set body [dict create candidates [list [dict create content [dict create parts [list [dict create text gemini]]]]] usageMetadata [dict create promptTokenCount 1 candidatesTokenCount 2 thoughtsTokenCount 3 cacheTokensDetails [dict create cachedContentTokenCount 9] cacheWriteTokenCount 5]]
                set headers [dict create x-request-id req-gemini]
            }
        }
        return [dict create status_code 200 headers $headers body [::attractor_core::json_encode $body]]
    }
    set client [::unified_llm::client_new -provider openai -transport ::tests::unified_llm::transport_metadata]
} -body {
    set a [::unified_llm::generate -client $client -provider openai -prompt x -model gpt-4.1 -max_tool_rounds 0]
    set b [::unified_llm::generate -client $client -provider anthropic -prompt x -model claude -max_tool_rounds 0]
    set c [::unified_llm::generate -client $client -provider gemini -prompt x -model gemini-1.5-pro -max_tool_rounds 0]
    list \
      [dict get $a usage reasoning_tokens] \
      [dict get $a usage cache_read_tokens] \
      [dict get $a usage cache_write_tokens] \
      [dict get $b usage cache_read_tokens] \
      [dict get $c usage cache_read_tokens] \
      [dict get $c usage cache_write_tokens] \
      [dict get $a metadata x-request-id] \
      [dict get $b metadata request-id] \
      [dict get $c metadata x-request-id]
} -cleanup {
    rename ::tests::unified_llm::transport_metadata {}
    $client close
} -result {2 7 4 6 9 5 req-openai req-anthropic req-gemini}

test unified_llm-provider-options-validation-1.0 {provider options malformed fails fast} -setup {
    set client [::unified_llm::client_new -provider anthropic]
} -body {
    catch {::unified_llm::generate -client $client -provider anthropic -prompt x -provider_options [dict create beta_headers [list ""]]} err opts
    list [dict get $opts -errorcode] [string match "*beta_headers*" $err]
} -cleanup {
    $client close
} -result {{UNIFIED_LLM INPUT INVALID_PROVIDER_OPTIONS} 1}

test unified_llm-provider-options-headers-1.0 {provider-specific headers are set from provider_options} -setup {
    proc ::tests::unified_llm::transport_headers {req} {
        return [dict create status_code 200 headers {} body [::attractor_core::json_encode [dict create output_text ok usage [dict create input_tokens 1 output_tokens 1 reasoning_tokens 0 cache_read_tokens 0 cache_write_tokens 0]]]]
    }
    set client [::unified_llm::client_new -provider anthropic -transport ::tests::unified_llm::transport_headers]
} -body {
    set _ [::unified_llm::generate -client $client -provider anthropic -prompt x -model claude -provider_options [dict create beta_headers [list tools-2024-04-04] extra_headers [dict create x-test abc]]]
    set response [::unified_llm::generate -client $client -provider openai -prompt x -model gpt-4.1 -provider_options [dict create extra_headers [dict create x-openai-test v]]]
    list [dict exists [dict get $response request headers] x-openai-test]
} -cleanup {
    rename ::tests::unified_llm::transport_headers {}
    $client close
} -result {1}

test unified_llm-multimodal-openai-1.0 {image url/base64/path parts are translated} -setup {
    set work [file join $root .scratch verification SPRINT-003 ullm image-[pid].png]
    file mkdir [file dirname $work]
    set fh [open $work w]
    fconfigure $fh -translation binary -encoding iso8859-1
    puts -nonewline $fh "PNGDATA"
    close $fh

    set ::tests::unified_llm::requests {}
    proc ::tests::unified_llm::transport_multimodal {req} {
        dict lappend ::tests::unified_llm::requests reqs $req
        set body [dict create output_text ok usage [dict create input_tokens 1 output_tokens 1 reasoning_tokens 0 cache_read_tokens 0 cache_write_tokens 0]]
        return [dict create status_code 200 headers {} body [::attractor_core::json_encode $body]]
    }
    set client [::unified_llm::client_new -provider openai -transport ::tests::unified_llm::transport_multimodal]
} -body {
    set msg [::unified_llm::message user [list \
        [dict create type text text hello] \
        [dict create type image_url url https://example.com/a.png] \
        [dict create type image_base64 mime_type image/png data UEs=] \
        [dict create type image_path path $work]]]
    set _ [::unified_llm::generate -client $client -provider openai -messages [list $msg] -model gpt-4.1 -max_tool_rounds 0]
    set payload [dict get [lindex [dict get $::tests::unified_llm::requests reqs] 0] payload]
    set content [dict get [lindex [dict get $payload input] 0] content]
    list [llength $content] [dict get [lindex $content 1] type] [string first "data:image/png;base64," [dict get [lindex $content 3] image_url]]
} -cleanup {
    rename ::tests::unified_llm::transport_multimodal {}
    file delete -force $work
    $client close
} -result {4 input_image 0}
